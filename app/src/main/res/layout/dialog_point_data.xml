<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="Данные о точке"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Номер -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Номер"
        android:textSize="13sp"
        android:textColor="@color/gray"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/pointNumberText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_background_registration"
        android:padding="10dp"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <!-- Номер учётного дерева -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Номер учётного дерева"
        android:textSize="13sp"
        android:textColor="@color/gray"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/treeNumberText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_background_registration"
        android:padding="10dp"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <!-- Широта -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Широта"
        android:textSize="13sp"
        android:textColor="@color/gray"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/latitudeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_background_registration"
        android:padding="10dp"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <!-- Долгота -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Долгота"
        android:textSize="13sp"
        android:textColor="@color/gray"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/longitudeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_background_registration"
        android:padding="10dp"
        android:textSize="15sp"
        android:layout_marginBottom="20dp" />

    <!-- Разделитель + кнопка -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/underline"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_margin="8dp"
            android:background="@color/black"
            app:layout_constraintBottom_toTopOf="@+id/closeButton"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/closeButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/back_button"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:text="@string/close"
            android:textColor="@color/black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>