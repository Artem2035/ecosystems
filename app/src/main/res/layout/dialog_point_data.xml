<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Заголовок — всегда сверху, не скролится -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:paddingBottom="8dp"
        android:text="Данные о точке"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Скролируемая область -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- Номер -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Номер"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/pointNumberEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_background_registration"
                android:padding="10dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <!-- Широта -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Широта"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/latitudeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_background_registration"
                android:padding="10dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <!-- Долгота -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Долгота"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/longitudeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_background_registration"
                android:padding="10dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <!-- Динамические свойства -->
            <LinearLayout
                android:id="@+id/propertiesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/underline"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/black"
                    app:layout_constraintBottom_toTopOf="@+id/closeButton"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:layout_editor_absoluteX="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/closeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/back_button"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:text="@string/close"
                    android:textColor="@color/black"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/deletePointButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/delete_button"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:text="Удалить"
                    android:textColor="@color/white"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/closeButton" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/savePointValuesButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/back_button_registration"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:text="Сохранить"
                    android:textColor="@color/white"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>