<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- Верхняя панель с кнопкой закрытия -->
    <FrameLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#0D0D1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Разметка изображения"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnClose"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"/>

    </FrameLayout>

    <!-- Контейнер для фото и оверлея -->
    <FrameLayout
        android:id="@+id/photoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/toolbarBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.github.chrisbanes.photoview.PhotoView
            android:id="@+id/photoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>

        <com.example.ecosystems.PhotoViewDialog.DrawingOverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

    <!-- Нижняя панель инструментов -->
    <HorizontalScrollView
        android:id="@+id/toolbarBottom"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#16213E"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigate"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="2dp"
                android:text="✋"
                android:textSize="20sp"
                android:textColor="#E0E0E0"
                android:paddingHorizontal="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRectangle"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="2dp"
                android:text="▭"
                android:textSize="20sp"
                android:textColor="#E0E0E0"
                android:paddingHorizontal="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPolygon"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:text="⬠"
                android:textSize="20sp"
                android:textColor="#E0E0E0"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMagicWand"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:text="Magic Wand"
                android:textColor="#E0E0E0"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="2dp"
                android:text="🗑"
                android:textSize="20sp"
                android:textColor="#FF5555"
                android:paddingHorizontal="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUndo"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="2dp"
                android:text="↩"
                android:textSize="20sp"
                android:textColor="#E0E0E0"
                android:paddingHorizontal="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="#0F3460"
                android:text="✓"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <!-- Новые кнопки просто добавляются сюда -->

        </LinearLayout>
    </HorizontalScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>